# --- Core ---
PORT=5050
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-to-a-long-random-string

# --- MongoDB Atlas (required) ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/forwardly_leads?retryWrites=true&w=majority

# --- Seed super-admin (created by `npm run seed`) ---
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@forwardly.in
ADMIN_PASSWORD=admin123

# --- Leads: Google Places (optional; mock data used if empty) ---
GOOGLE_MAPS_API_KEY=

# --- Assignment rules ---
DAILY_CAP_PER_AGENT=50

# --- Cron (server local time). Default 3:00 AM daily ---
INGEST_CRON=0 3 * * *
TIMEZONE=Asia/Kolkata
# secret for external schedulers to hit GET /api/cron/run?key=...
CRON_SECRET=

# secret for an external BNI scraper/DAG to POST /api/bni-leads/ingest?key=...
BNI_INGEST_SECRET=

# --- AI research/pitch (optional) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
