# Copy to .env in this same folder and fill in real values.
# All of these are captured from your browser's DevTools Network tab while
# logged into BNI Connect — they expire, so re-capture when the script
# starts failing with "token/cookie expired".

# Defaults already point at the real hosts (confirmed live) — only override
# if your account is on a different regional deployment.
BNI_BASE_URL=https://www.bniconnectglobal.com
BNI_API_BASE_URL=https://api.bniconnectglobal.com

# Optional — confirmed live that BNI_MTOKEN works for the search endpoint
# too, so this can usually be left blank. Only set it if that ever changes.
BNI_SEARCH_TOKEN=

# Full Cookie header value sent to GET /web/secure/networkHome
# e.g. AUTH_INIT=Connect; JSESSIONID=...; OLDSESSIONID=...
BNI_COOKIE=

# The mtoken JWT (same one that appears as ?mtoken=... on /web/member/),
# sent as Bearer auth to member-api/v2/home
BNI_MTOKEN=

# Optional but recommended: set these and the scraper will auto re-mint a
# fresh BNI_MTOKEN itself (via auth-api/authenticate, the same call the
# site's login page makes) whenever the current one expires — no more
# manually pasting a fresh curl every ~2 hours. Does NOT fix a stale
# BNI_COOKIE though — that's a separate, session-based credential with no
# known API-only renewal, so it still needs a manual browser recapture.
BNI_CLIENT_ID=IDENTITY_PORTAL
BNI_CLIENT_SECRET=
BNI_USERNAME=
BNI_PASSWORD=

# Confirmed working endpoint: {BNI_API_BASE_URL}/member-api/v2/home?uuId={uuId}
# Only set this if you need to override the default.
BNI_PROFILE_URL_TEMPLATE=

# Comma-separated industry keywords to search (matches search_keywords field)
BNI_INDUSTRIES=architects,interior designer,real estate,construction

BNI_CONCEPT_ID=1
BNI_LOCALE=en_IN
BNI_PER_PAGE=20

# Optional cap on pages fetched per industry, to bound total runtime given
# the token's ~hourly expiry and no auto-refresh. Leave blank for no cap.
BNI_MAX_PAGES_PER_INDUSTRY=

# Randomized delay between requests, in ms. 300-800 was tried against the
# real API and triggered sustained 429s after ~2 pages — bumped up.
BNI_DELAY_MIN_MS=1500
BNI_DELAY_MAX_MS=3000

# Output paths are relative to this folder
BNI_OUTPUT_FILE=output/bni_leads.csv
BNI_STATE_FILE=output/state.json
BNI_ERROR_LOG_FILE=output/errors.log

# Optional: also push each scraped lead live to a deployed forwardly-leads
# backend via POST /api/bni-leads/ingest, in addition to the local CSV.
# Leave blank to only write locally. Secret must match BNI_INGEST_SECRET
# in that backend's own .env.
FORWARDLY_API_URL=
FORWARDLY_INGEST_SECRET=
