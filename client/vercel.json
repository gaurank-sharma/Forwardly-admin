{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://forwardly-admin.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://forwardly-admin.onrender.com/uploads/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
